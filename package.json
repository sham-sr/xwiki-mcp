{
  "name": "xwiki-mcp",
  "version": "0.2.0",
  "description": "MCP server for XWiki REST API — full-text Solr search + read/write tools for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "xwiki-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --exclude 'dist/**'",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "xwiki",
    "model-context-protocol",
    "claude",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vitos73/xwiki-mcp.git"
  },
  "homepage": "https://github.com/vitos73/xwiki-mcp",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
